            </div>

            <div class="programs-fluid-grid">
                <!-- Elite Academia -->
                <a href="/program/elite-academia" class="program-tile">
                    <img src="/images/home/IMG_9060.jpg.jpeg" alt="Elite Academia">
                    <div class="program-tile-overlay">
                        <h3>Elite Academia</h3>
                        <span>Pelajari Selengkapnya &rarr;</span>
                    </div>
                </a>

                <!-- Playetracy -->
                <a href="/program/playetracy" class="program-tile">
                    <img src="/images/home/IMG_9061.jpg.jpeg" alt="Playetracy">
