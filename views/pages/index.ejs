            <div class="hero-bg" style="background-image: url('/images/home/IMG_9444.jpg.jpeg')">
            </div>
            <div class="container hero-container hero-container-home">
                <div class="hero-values-circle">
                    <h2>Seven Values</h2>
                    <p class="values-list">
                        Respect, Independent, Religious, Accomplished, Knowledgeable, Integrity, Socially Responsible
                    </p>
                </div>
            </div>
        </section>

        <!-- Intro Section -->
        <section class="section intro-static intro-home">
