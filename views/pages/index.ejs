                        <img src="/images/home/IMG_9597.jpg.jpeg" class="circle-img circle-img-2" alt="Student Writing">
                        <img src="/images/home/IMG_9061.jpg.jpeg" class="circle-img circle-img-3"
                            alt="Student Learning">
                    </div>
                </div>
            </div>
        </section>

        <!-- Accreditation Section -->
        <section class="section accreditation-logos-section">
            <div class="container text-center">
                <div class="accreditation-logos-row">
