<%- include('../partials/head') %>
    <%- include('../partials/nav') %>

        <section class="page-mission-vision">
            <!-- Decorative Shapes -->
            <div class="decor-vm-top-right"></div>
            <div class="decor-vm-mid-left" style="top: 20%; left: -100px; transform: rotate(45deg);"></div>
            <div class="decor-vm-bot-right"
                style="bottom: 100px; right: 5%; width: 150px; height: 150px; border-radius: 150px 0 150px 150px;">
            </div>

            <div class="container container-vm" style="position: relative; z-index: 2;">
                <div class="breadcrumb breadcrumb-center" style="justify-content: center; margin-top: 60px;">
                    <a href="/">Homepage</a><span>|</span><a href="#">About Us</a><span>|</span><span
                        style="color: var(--primary-blue); font-weight: 500;">Foundation</span>
                </div>

                <div class="vm-block vm-visi text-center"
                    style="position: relative; margin-bottom: 80px; margin-top: 50px;">
                    <h2 style="font-size: 2.2rem; color: var(--primary-blue); margin-bottom: 30px; font-weight: 700;">
                        Yayasan Sinar Putih Edelweiss</h2>
                    <div class="vm-quote-icon"
                        style="position: absolute; right: 10%; top: -20px; background: rgba(245, 194, 66, 0.2); width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--primary-blue); font-size: 1.8rem;">
                        <i class="far fa-comment-dots"></i>
                    </div>
                    <p class="visi-text"
                        style="font-size: 1.05rem; color: var(--gray-600); line-height: 1.8; max-width: 800px; margin: 0 auto;">
                        Yayasan Sinar Putih Edelweiss didirikan pada tanggal 29 Maret 2005, dengan tujuan untuk
                        menyelenggarakan layanan world class education melalui berbagai program yang berorientasi pada
                        pengembangan potensi individu secara menyeluruh. Yayasan Sinar Putih Edelweiss berkomitmen untuk
                        menumbuhkembangkan generasi yang cerdas, berkarakter, berjiwa nasionalis, dan memiliki wawasan
                        global.</p>
                </div>

                <div class="foundation-services" style="max-width: 1000px; margin: 0 auto;">
                    <h3 style="color: var(--primary-blue); font-size: 1.4rem; margin-bottom: 30px; font-weight: 700;">
                        Yayasan Sinar Putih Edelweiss <span
                            style="font-size: 1.1rem; color: var(--blue-light); font-weight: 500; margin-left:10px;">Menaungi
                            dua layanan pendidikan utama yaitu:</span></h3>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-bottom: 80px;">
                        <!-- Edelweiss School -->
                        <div
                            style="background: var(--gray-50); border-radius: var(--radius-lg); padding: 40px; position: relative; overflow: hidden; box-shadow: var(--shadow-sm);">
                            <div
                                style="position: absolute; left: 0; top: 0; width: 60px; height: 100%; background: var(--bg-yellow); opacity: 0.5;">
                            </div>
                            <h4
                                style="color: var(--primary-blue); font-size: 1.4rem; margin-bottom: 15px; position: relative; z-index: 2; padding-left: 20px;">
                                Edelweiss School</h4>
                            <p
                                style="color: var(--gray-600); font-size: 1rem; line-height: 1.6; position: relative; z-index: 2; padding-left: 20px;">
                                Penyelenggara pendidikan formal yang berfokus pada pembelajaran holistik melalui jenjang
                                KB, TK, SD dan SMP</p>
                        </div>

                        <!-- Edelweiss Learning Center -->
                        <div
                            style="background: var(--gray-50); border-radius: var(--radius-lg); padding: 40px; position: relative; overflow: hidden; box-shadow: var(--shadow-sm);">
                            <div
                                style="position: absolute; right: 0; top: 0; width: 60px; height: 100%; background: rgba(26, 61, 107, 0.05);">
                            </div>
                            <h4
                                style="color: var(--primary-blue); font-size: 1.4rem; margin-bottom: 15px; position: relative; z-index: 2;">
                                Edelweiss Learning Center</h4>
                            <p
                                style="color: var(--gray-600); font-size: 1rem; line-height: 1.6; position: relative; z-index: 2;">
                                Penyelenggara pendidikan non formal seperti Elite Academia Homeschooling, Playetracy,
                                English Course, dan Indonesia Pedagogic Development Center</p>
                        </div>
                    </div>
                </div>

                <div class="foundation-logos"
                    style="display: flex; justify-content: center; gap: 60px; margin-bottom: 60px;">
                    <div style="text-align: center;">
                        <img src="/images/figma/Program%20Kami.png" alt="Edelweiss School" style="height: 60px;">
                    </div>
                    <div style="text-align: center;">
                        <img src="/images/figma/Kurikulum%20Kami.png" alt="Edelweiss Learning Center"
                            style="height: 60px;">
                    </div>
                </div>
            </div>
        </section>

        <%- include('../partials/footer') %>