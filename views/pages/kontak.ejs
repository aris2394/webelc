<%- include('../partials/head') %>
    <%- include('../partials/nav') %>

        <section class="page-hero">
            <div class="container">
                <div class="breadcrumb">
                    <a href="/">Homepage</a><span>|</span><span>Kontak</span>
                </div>
                <h1>Hubungi Kami</h1>
                <p>Kami siap membantu Anda. Silakan hubungi kami melalui salah satu cara di bawah ini.</p>
            </div>
        </section>

        <section class="contact-form-section">
            <div class="container">
                <div class="contact-grid">
                    <div>
                        <h2 style="margin-bottom: 24px;">Kirim Pesan</h2>
                        <form>
                            <div class="form-group">
                                <label for="name">Nama Lengkap</label>
                                <input type="text" id="name" placeholder="Masukkan nama lengkap Anda">
                            </div>
                            <div class="form-group">
                                <label for="email">Email</label>
                                <input type="email" id="email" placeholder="contoh@email.com">
                            </div>
                            <div class="form-group">
                                <label for="phone">No. Telepon</label>
                                <input type="tel" id="phone" placeholder="Contoh: 081234567890">
                            </div>
                            <div class="form-group">
                                <label for="subject">Subjek</label>
                                <input type="text" id="subject" placeholder="Tentang apa pesan Anda?">
                            </div>
                            <div class="form-group">
                                <label for="contactMessage">Pesan</label>
                                <textarea id="contactMessage" placeholder="Tulis pesan Anda di sini..."></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
                                Kirim Pesan <i class="fas fa-paper-plane"></i>
                            </button>
                        </form>
                    </div>
                    <div>
                        <h2 style="margin-bottom: 24px;">Informasi Kontak</h2>
                        <div class="contact-info-cards">
                            <div class="contact-info-card">
                                <div class="icon"><i class="fas fa-map-marker-alt"></i></div>
                                <div>
                                    <h4>Alamat</h4>
                                    <p>Jl. Margasatwa Raya No. 1B, Pondok Labu, Cilandak, Jakarta Selatan 12450</p>
                                </div>
                            </div>
                            <div class="contact-info-card">
                                <div class="icon"><i class="fas fa-phone-alt"></i></div>
                                <div>
                                    <h4>Telepon</h4>
                                    <p>(021) 7884-5678</p>
                                </div>
                            </div>
                            <div class="contact-info-card">
                                <div class="icon"><i class="fas fa-envelope"></i></div>
                                <div>
                                    <h4>Email</h4>
                                    <p>info@edelweisslc.sch.id</p>
                                </div>
                            </div>
                            <div class="contact-info-card">
                                <div class="icon"><i class="fab fa-instagram"></i></div>
                                <div>
                                    <h4>Instagram</h4>
                                    <p>@edelweisslearningcenter</p>
                                </div>
                            </div>
                            <div class="contact-info-card">
                                <div class="icon"><i class="fas fa-clock"></i></div>
                                <div>
                                    <h4>Jam Operasional</h4>
                                    <p>Senin - Jumat: 08.00 - 16.00 WIB<br>Sabtu: 08.00 - 12.00 WIB</p>
                                </div>
                            </div>
                        </div>

                        <!-- Map placeholder -->
                        <div
                            style="margin-top: 24px; border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-md);">
                            <iframe
                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3965.5!2d106.79!3d-6.33!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNsKwMjAnUyAxMDbCsDQ3J0U!5e0!3m2!1sid!2sid!4v1!"
                                width="100%" height="250" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <%- include('../partials/footer') %>